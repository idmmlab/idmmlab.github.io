<div class="news">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    <div
      class="table-responsive"
      {% if include.limit and page.announcements.scrollable and news_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign news = site.news | reverse %}
        {% if include.limit and page.announcements.limit %}
          {% assign news_limit = page.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% for item in news limit: news_limit %}
          {% assign slug = item.path | replace: '_news/', '' | replace: '.md', '' %}
          {% if include.compact %}
            {% assign compact_html = item.content
              | remove: '<p>'
              | remove: '</p>'
              | replace: '<a href=', '<span data-href='
              | replace: '</a>', '</span>'
              | emojify %}
            <tr>
              <th scope="row" style="width: 20%">{{ item.date | date: '%b %d, %Y' }}</th>
              <td>
                <a class="news-compact-link" href="{{ '/news/' | relative_url }}#news-{{ slug }}">
                  {{ compact_html }}
                </a>
              </td>
            </tr>
          {% else %}
            <tr id="news-{{ slug }}">
              <th scope="row" style="width: 20%">{{ item.date | date: '%b %d, %Y' }}</th>
              <td>
                {% if item.image %}
                  <img
                    src="{{ item.image | relative_url }}"
                    alt="{{ item.image_alt | default: '' }}"
                    class="news-detail-img"
                    style="float: right; max-width: 130px; margin: 0 0 0.75rem 1rem; border-radius: 4px;">
                {% endif %}
                {{ item.content | emojify }}
              </td>
            </tr>
          {% endif %}
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
